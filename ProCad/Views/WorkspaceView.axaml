<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ProCad.ViewModels"
             xmlns:dock="using:Dock.Avalonia.Controls"
             xmlns:recycling="using:Avalonia.Controls.Recycling"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ProCad.Views.WorkspaceView"
             x:DataType="vm:WorkspaceViewModel">
  <UserControl.Resources>
    <recycling:ControlRecycling x:Key="DockControlRecycling"
                                TryToUseIdAsKey="True" />
  </UserControl.Resources>
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Background="{DynamicResource ThemeControlLowBrush}"
            Padding="8">
      <StackPanel Orientation="Horizontal"
                  Spacing="8">
        <Button Classes="fluent-icon" Tag="{StaticResource NewDocumentIconPath}" Content="New"
                Command="{CompiledBinding NewCommand}" />
        <Button Classes="fluent-icon" Tag="{StaticResource OpenFolderIconPath}" Content="Open"
                Command="{CompiledBinding OpenCommand}" />
        <Button Classes="fluent-icon" Tag="{StaticResource SaveIconPath}" Content="Save"
                Command="{CompiledBinding SaveCommand}" />
        <Button Classes="fluent-icon" Tag="{StaticResource SaveAsIconPath}" Content="Save As"
                Command="{CompiledBinding SaveAsCommand}" />
        <Button Classes="fluent-icon" Tag="{StaticResource CompareIconPath}" Content="Compare"
                Command="{CompiledBinding CompareCommand}" />
      </StackPanel>
    </Border>
    <dock:DockControl Grid.Row="1"
                      Layout="{Binding Layout}"
                      Factory="{Binding Factory}"
                      recycling:ControlRecyclingDataTemplate.ControlRecycling="{StaticResource DockControlRecycling}"
                      InitializeLayout="False"
                      InitializeFactory="True" />
    <Border Grid.Row="2"
            Background="{DynamicResource ThemeControlLowBrush}"
            Padding="8"
            IsVisible="{CompiledBinding FastPathDiagnostics.IsEnabled}">
      <StackPanel Orientation="Horizontal"
                  Spacing="8">
        <TextBlock Text="FastPath warnings:"
                   FontWeight="SemiBold" />
        <TextBlock Text="{CompiledBinding FastPathDiagnostics.StatusText}"
                   TextTrimming="CharacterEllipsis" />
        <Button Classes="fluent-icon" Tag="{StaticResource ClearIconPath}" Content="Clear"
                Command="{CompiledBinding ClearDiagnosticsCommand}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
