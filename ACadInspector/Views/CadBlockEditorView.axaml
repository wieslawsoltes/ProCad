<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ACadInspector.ViewModels"
             xmlns:views="using:ACadInspector.Views"
             mc:Ignorable="d"
             x:Class="ACadInspector.Views.CadBlockEditorView"
             x:DataType="vm:CadBlockEditorViewModel">
  <Grid Margin="16"
        RowDefinitions="Auto,*"
        RowSpacing="8">
    <Border Background="{DynamicResource ThemeControlLowBrush}"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10">
      <StackPanel Spacing="6">
        <StackPanel Orientation="Horizontal"
                    Spacing="8">
          <TextBlock Text="Block Editor"
                     FontWeight="SemiBold" />
          <TextBlock Text="{CompiledBinding BlockName}" />
        </StackPanel>
        <Grid ColumnDefinitions="Auto,*,Auto,Auto"
              ColumnSpacing="8">
          <TextBlock Text="Name"
                     VerticalAlignment="Center" />
          <TextBox Grid.Column="1"
                   Text="{CompiledBinding BlockName, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Grid.Column="2"
                     Text="Units"
                     VerticalAlignment="Center" />
          <ComboBox Grid.Column="3"
                    Width="140"
                    ItemsSource="{CompiledBinding UnitOptions}"
                    SelectedItem="{CompiledBinding BlockUnits}" />
        </Grid>
        <Grid ColumnDefinitions="Auto,*"
              ColumnSpacing="8">
          <TextBlock Text="Description"
                     VerticalAlignment="Center" />
          <TextBox Grid.Column="1"
                   Text="{CompiledBinding BlockDescription, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>
        <StackPanel Orientation="Horizontal"
                    Spacing="8">
          <ToggleButton Content="Show Attributes"
                        IsChecked="{CompiledBinding ShowAttributes}" />
          <ToggleButton Content="Show Attr Defs"
                        IsChecked="{CompiledBinding ShowAttributeDefinitions}" />
          <TextBlock Text="Visibility"
                     VerticalAlignment="Center"
                     IsVisible="{CompiledBinding HasVisibilityStates}" />
          <ComboBox Width="180"
                    ItemsSource="{CompiledBinding VisibilityStateOptions}"
                    SelectedItem="{CompiledBinding SelectedVisibilityState}"
                    IsVisible="{CompiledBinding HasVisibilityStates}" />
        </StackPanel>
        <StackPanel Spacing="4"
                    IsVisible="{CompiledBinding HasDynamicMetadata}">
          <TextBlock Text="Dynamic"
                     FontWeight="SemiBold" />
          <ItemsControl ItemsSource="{CompiledBinding DynamicParameters}">
            <ItemsControl.DataTemplates>
              <DataTemplate x:DataType="vm:CadDynamicBlockLinearParameterViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                      ColumnSpacing="8"
                      Margin="0,2">
                  <TextBlock Text="{CompiledBinding Name}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="{CompiledBinding Label}"
                             VerticalAlignment="Center"
                             Opacity="0.7" />
                  <TextBlock Grid.Column="2"
                             Text="{CompiledBinding CurrentValueLabel}"
                             VerticalAlignment="Center" />
                  <ToggleButton Grid.Column="3"
                                Content="Override"
                                IsChecked="{CompiledBinding OverrideEnabled}" />
                  <NumericUpDown Grid.Column="4"
                                 Width="90"
                                 Value="{CompiledBinding OverrideValue}"
                                 IsEnabled="{CompiledBinding OverrideEnabled}" />
                </Grid>
              </DataTemplate>
              <DataTemplate x:DataType="vm:CadDynamicBlockFlipParameterViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                      ColumnSpacing="8"
                      Margin="0,2">
                  <TextBlock Text="{CompiledBinding Name}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="{CompiledBinding Label}"
                             VerticalAlignment="Center"
                             Opacity="0.7" />
                  <TextBlock Grid.Column="2"
                             Text="{CompiledBinding CurrentStateLabel}"
                             VerticalAlignment="Center" />
                  <ToggleButton Grid.Column="3"
                                Content="Override"
                                IsChecked="{CompiledBinding OverrideEnabled}" />
                  <ToggleButton Grid.Column="4"
                                Content="Flipped"
                                IsChecked="{CompiledBinding IsFlipped}"
                                IsEnabled="{CompiledBinding OverrideEnabled}" />
                </Grid>
              </DataTemplate>
              <DataTemplate x:DataType="vm:CadDynamicBlockVisibilityParameterViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8"
                      Margin="0,2">
                  <TextBlock Text="{CompiledBinding Name}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="{CompiledBinding CurrentState}"
                             VerticalAlignment="Center"
                             Opacity="0.7" />
                  <TextBlock Grid.Column="2"
                             Text="(Use header control)"
                             VerticalAlignment="Center"
                             Opacity="0.6" />
                </Grid>
              </DataTemplate>
            </ItemsControl.DataTemplates>
          </ItemsControl>
          <ItemsControl ItemsSource="{CompiledBinding DynamicActions}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CadDynamicBlockActionViewModel">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8"
                      Margin="0,2">
                  <TextBlock Text="{CompiledBinding Type}"
                             VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1"
                             Text="{CompiledBinding Name}"
                             VerticalAlignment="Center"
                             Opacity="0.7" />
                  <TextBlock Grid.Column="2"
                             Text="{CompiledBinding EntityCount}"
                             VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </StackPanel>
    </Border>
    <Border Grid.Row="1"
            CornerRadius="12"
            BorderThickness="1"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}">
      <views:CadRenderView DataContext="{CompiledBinding Render}" />
    </Border>
  </Grid>
</UserControl>
