<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ACadInspector.ViewModels"
             xmlns:controls="using:ACadInspector.Controls"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:behaviors="using:ACadInspector.Behaviors"
             mc:Ignorable="d"
             x:Class="ACadInspector.Views.CadRenderView"
             x:DataType="vm:CadRenderViewModel">
  <UserControl.Styles>
    <Style Selector="TabStrip#LayoutTabs">
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="TabStrip#LayoutTabs > TabStripItem">
      <Setter Property="Padding" Value="10,3" />
      <Setter Property="Margin" Value="2,0" />
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="FontSize" Value="12" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="74,*,Auto,Auto">
    <Border Padding="8,4"
            CornerRadius="10"
            Background="{DynamicResource ThemeControlLowBrush}"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
            BorderThickness="1"
            Margin="12,8,12,6"
            Height="62"
            ClipToBounds="True">
      <DockPanel LastChildFill="True">
        <StackPanel Orientation="Horizontal"
                    Spacing="8"
                    DockPanel.Dock="Left">
          <Button Classes="fluent-icon" Tag="{StaticResource FitViewIconPath}" Content="Fit"
                  Command="{CompiledBinding FitCommand}" />
          <Button Classes="fluent-icon" Tag="{StaticResource ResetViewIconPath}" Content="Reset"
                  Command="{CompiledBinding ResetCommand}" />
          <ToggleButton Classes="fluent-icon" Tag="{StaticResource GridIconPath}" Content="Grid"
                        IsChecked="{CompiledBinding ShowGrid}" />
          <ToggleButton Classes="fluent-icon" Tag="{StaticResource AxesIconPath}" Content="Axes"
                        IsChecked="{CompiledBinding ShowAxes}" />
        </StackPanel>
        <Grid HorizontalAlignment="Right"
              Width="520"
              Height="54"
              RowDefinitions="Auto,Auto,Auto"
              ClipToBounds="True">
          <TextBlock Grid.Row="0"
                     Text="{CompiledBinding ActiveCommandPrompt}"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Right"
                     TextWrapping="NoWrap"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="520" />
          <TextBlock Grid.Row="1"
                     Text="{CompiledBinding ActiveCommandHelp}"
                     FontSize="11"
                     Opacity="0.8"
                     HorizontalAlignment="Right"
                     TextWrapping="NoWrap"
                     TextTrimming="CharacterEllipsis"
                     MaxWidth="520" />
          <DockPanel Grid.Row="2"
                     LastChildFill="True"
                     Height="22"
                     ClipToBounds="True">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          IsVisible="{CompiledBinding HasCanvasCompletions}"
                          DockPanel.Dock="Left"
                          Width="320">
              <ItemsControl ItemsSource="{CompiledBinding CanvasCompletions}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"
                                Spacing="4" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CadCommandCompletionItemViewModel">
                    <Button Content="{CompiledBinding DisplayText}"
                            Command="{CompiledBinding ApplyCommand}"
                            CommandParameter="{CompiledBinding .}"
                            Padding="6,1"
                            MinHeight="20" />
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          IsVisible="{CompiledBinding HasActiveVisualHelpers}">
              <ItemsControl ItemsSource="{CompiledBinding ActiveVisualHelpers}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"
                                Spacing="4" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CadVisualHelperBadgeViewModel">
                    <Border Background="{DynamicResource ThemeControlMidBrush}"
                            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="6,2">
                      <TextBlock Text="{CompiledBinding Label}"
                                 FontSize="10"
                                 TextWrapping="NoWrap"
                                 TextTrimming="CharacterEllipsis" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </Grid>
      </DockPanel>
    </Border>

    <controls:CadRenderControl Grid.Row="1"
                               Scene="{CompiledBinding Scene}"
                               ShowGrid="{CompiledBinding ShowGrid}"
                               ShowAxes="{CompiledBinding ShowAxes}"
                               EnableInteractionOptimization="{CompiledBinding EnableInteractionOptimization}"
                               LayerVisibilityOverrides="{CompiledBinding LayerList.LayerVisibilityOverrides}"
                               EntityTypeVisibilityOverrides="{CompiledBinding EntityTypeList.EntityTypeVisibilityOverrides}"
                               FitToViewTrigger="{CompiledBinding FitRequest}"
                               ResetViewTrigger="{CompiledBinding ResetRequest}"
                               FitOnSceneChange="{CompiledBinding FitOnLoad}"
                               ShowDebugOverlay="{CompiledBinding ShowDebugOverlay}"
                               HoverBounds="{CompiledBinding HoverBounds}"
                               SelectionBounds="{CompiledBinding SelectionBounds}"
                               HoverAnnotation="{CompiledBinding HoverAnnotation}"
                               SelectionAnnotation="{CompiledBinding SelectionAnnotation}"
                               OverlayScene="{CompiledBinding OverlayScene}"
                               DynamicInput="{CompiledBinding DynamicInput}"
                               FocusRequest="{CompiledBinding FocusRequest}"
                               DebugBvhBounds="{CompiledBinding DebugBvhBounds}">
      <i:Interaction.Behaviors>
        <behaviors:CadInsertDropBehavior DropCommand="{CompiledBinding InsertDroppedBlockCommand}" />
        <behaviors:CadRenderHitTestBehavior InteractionCommand="{CompiledBinding InteractionCommand}"
                                            HoverTolerancePixels="4"
                                            SelectionTolerancePixels="6"
                                            HoverThrottleMs="40" />
      </i:Interaction.Behaviors>
    </controls:CadRenderControl>

    <Border Grid.Row="2"
            Margin="12,6,12,2"
            Padding="6,2"
            CornerRadius="10"
            Background="{DynamicResource ThemeControlLowBrush}"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
            BorderThickness="1">
      <DockPanel LastChildFill="True">
        <StackPanel Orientation="Horizontal"
                    Spacing="6"
                    DockPanel.Dock="Right">
          <ToggleButton Classes="fluent-icon" Tag="{StaticResource TargetIconPath}" Content="OSNAP"
                        IsChecked="{CompiledBinding OsnapEnabled}" />
          <ToggleButton Classes="fluent-icon" Tag="{StaticResource LocationArrowIconPath}" Content="OTRACK"
                        IsChecked="{CompiledBinding OtrackEnabled}" />
          <ToggleButton Classes="fluent-icon" Tag="{StaticResource GridIconPath}" Content="ORTHO"
                        IsChecked="{CompiledBinding OrthoEnabled}" />
          <ToggleButton Classes="fluent-icon" Tag="{StaticResource AxesIconPath}" Content="POLAR"
                        IsChecked="{CompiledBinding PolarEnabled}" />
          <ToggleButton Classes="fluent-icon" Tag="{StaticResource TextTIconPath}" Content="DYNINPUT"
                        IsChecked="{CompiledBinding DynamicInputEnabled}" />
        </StackPanel>
        <TextBlock Text="{CompiledBinding InteractionStatus}"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
      </DockPanel>
    </Border>

    <Border Grid.Row="3"
            Margin="12,6,12,10"
            Padding="6,2"
            CornerRadius="10"
            Background="{DynamicResource ThemeControlLowBrush}"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
            BorderThickness="1"
            IsVisible="{CompiledBinding ShowLayoutTabs}">
      <TabStrip x:Name="LayoutTabs"
                ItemsSource="{CompiledBinding Layouts}"
                SelectedItem="{CompiledBinding SelectedLayout}">
        <TabStrip.ItemTemplate>
          <DataTemplate x:DataType="vm:CadRenderLayoutViewModel">
            <TextBlock Text="{CompiledBinding DisplayName}" />
          </DataTemplate>
        </TabStrip.ItemTemplate>
      </TabStrip>
    </Border>
  </Grid>
</UserControl>
