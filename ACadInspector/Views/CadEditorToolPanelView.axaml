<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ACadInspector.ViewModels"
             mc:Ignorable="d"
             x:Class="ACadInspector.Views.CadEditorToolPanelView"
             x:DataType="vm:CadEditorToolPanelViewModel">
  <ScrollViewer Margin="10"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <StackPanel Spacing="8">
      <Border Padding="8"
              CornerRadius="8"
              BorderBrush="{DynamicResource ThemeBorderLowBrush}"
              BorderThickness="1">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto"
              RowSpacing="6">
          <DockPanel LastChildFill="False">
            <TextBlock Text="{CompiledBinding ActiveCommand, StringFormat='Active: {0}'}"
                       FontWeight="SemiBold" />
            <Button DockPanel.Dock="Right"
                    Content="Esc"
                    Command="{CompiledBinding CancelCommand}" />
          </DockPanel>
          <TextBlock Grid.Row="1"
                     Text="{CompiledBinding ParameterHelp}"
                     TextWrapping="Wrap"
                     FontSize="11"
                     Opacity="0.88" />
          <TextBlock Grid.Row="2"
                     Text="{CompiledBinding StatusMessage}"
                     FontSize="11"
                     TextWrapping="Wrap"
                     Opacity="0.75"
                     IsVisible="{CompiledBinding HasStatusMessage}" />
          <ItemsControl Grid.Row="3"
                        ItemsSource="{CompiledBinding Completions}"
                        IsVisible="{CompiledBinding HasCompletions}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CadCommandCompletionItemViewModel">
                <Button Content="{CompiledBinding DisplayText}"
                        Command="{CompiledBinding $parent[vm:CadEditorToolPanelViewModel].ApplyCompletionCommand}"
                        CommandParameter="{CompiledBinding .}"
                        Margin="0,0,4,4"
                        MinHeight="24"
                        Padding="6,1" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>

      <Border CornerRadius="8"
              BorderBrush="{DynamicResource ThemeBorderLowBrush}"
              BorderThickness="1"
              Padding="6">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="6">
          <TextBlock Text="Draw"
                     FontWeight="SemiBold" />
          <ItemsControl Grid.Row="1"
                        ItemsSource="{CompiledBinding DrawTools}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CadEditorToolActionViewModel">
                <Button Content="{CompiledBinding DisplayName}"
                        Command="{CompiledBinding StartCommand}"
                        CommandParameter="{CompiledBinding Command}"
                        IsEnabled="{CompiledBinding $parent[vm:CadEditorToolPanelViewModel].CanStartTools}"
                        Margin="0,2" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>

      <Border CornerRadius="8"
              BorderBrush="{DynamicResource ThemeBorderLowBrush}"
              BorderThickness="1"
              Padding="6">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="6">
          <TextBlock Text="Modify"
                     FontWeight="SemiBold" />
          <ItemsControl Grid.Row="1"
                        ItemsSource="{CompiledBinding ModifyTools}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CadEditorToolActionViewModel">
                <Button Content="{CompiledBinding DisplayName}"
                        Command="{CompiledBinding StartCommand}"
                        CommandParameter="{CompiledBinding Command}"
                        IsEnabled="{CompiledBinding $parent[vm:CadEditorToolPanelViewModel].CanStartTools}"
                        Margin="0,2" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>

      <Border CornerRadius="8"
              BorderBrush="{DynamicResource ThemeBorderLowBrush}"
              BorderThickness="1"
              Padding="6">
        <Grid RowDefinitions="Auto,*"
              RowSpacing="6">
          <TextBlock Text="Annotate"
                     FontWeight="SemiBold" />
          <ItemsControl Grid.Row="1"
                        ItemsSource="{CompiledBinding AnnotateTools}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:CadEditorToolActionViewModel">
                <Button Content="{CompiledBinding DisplayName}"
                        Command="{CompiledBinding StartCommand}"
                        CommandParameter="{CompiledBinding Command}"
                        IsEnabled="{CompiledBinding $parent[vm:CadEditorToolPanelViewModel].CanStartTools}"
                        Margin="0,2" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
