<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ACadInspector.ViewModels"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:behaviors="using:ACadInspector.Behaviors"
             mc:Ignorable="d"
             x:Class="ACadInspector.Views.CadLogOutputToolView"
             x:DataType="vm:CadLogOutputToolViewModel">
  <Border Background="{DynamicResource ThemeControlLowBrush}"
          BorderBrush="{DynamicResource ThemeBorderLowBrush}"
          BorderThickness="1"
          Padding="10">
    <Grid RowDefinitions="Auto,*"
          RowSpacing="8">
      <StackPanel Orientation="Horizontal"
                  Spacing="8">
        <TextBlock Text="Log Output"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <Button Classes="fluent-icon" Tag="{StaticResource CopyIconPath}" Content="Copy Selected"
                ToolTip.Tip="Copy selected rows using ProDataGrid clipboard export.">
          <i:Interaction.Behaviors>
            <behaviors:DataGridCopySelectionBehavior GridName="LogGrid" />
          </i:Interaction.Behaviors>
        </Button>
        <Button Classes="fluent-icon" Tag="{StaticResource BroomIconPath}" Content="Clear Log"
                Command="{CompiledBinding ClearLogCommand}" />
        <TextBox Width="180"
                 Watermark="Search..."
                 Text="{CompiledBinding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        <Button Classes="fluent-icon" Tag="{StaticResource ClearIconPath}" Content="Clear"
                Command="{CompiledBinding ClearSearchCommand}" />
        <TextBox Width="180"
                 Watermark="Filter..."
                 Text="{CompiledBinding FilterText, UpdateSourceTrigger=PropertyChanged}" />
        <Button Classes="fluent-icon" Tag="{StaticResource ClearIconPath}" Content="Clear"
                Command="{CompiledBinding ClearFilterCommand}" />
      </StackPanel>
      <Grid Grid.Row="1"
            RowDefinitions="*,Auto"
            RowSpacing="6">
        <DataGrid x:Name="LogGrid"
                  ItemsSource="{CompiledBinding EntriesView}"
                  ColumnDefinitionsSource="{CompiledBinding ColumnDefinitions}"
                  SortingModel="{CompiledBinding SortingModel}"
                  FilteringModel="{CompiledBinding FilteringModel}"
                  SearchModel="{CompiledBinding SearchModel}"
                  AutoGenerateColumns="False"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  ClipboardCopyMode="IncludeHeader"
                  CanUserSortColumns="True"
                  CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="All"
                  IsReadOnly="True" />
        <TextBlock Grid.Row="1"
                   Text="{CompiledBinding StatusText}"
                   FontSize="11"
                   Opacity="0.85" />
      </Grid>
    </Grid>
  </Border>
</UserControl>
