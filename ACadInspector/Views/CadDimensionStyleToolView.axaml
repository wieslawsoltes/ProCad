<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ACadInspector.ViewModels"
             mc:Ignorable="d"
             x:Class="ACadInspector.Views.CadDimensionStyleToolView"
             x:DataType="vm:CadDimensionStyleToolViewModel">
  <Border Background="{DynamicResource ThemeControlLowBrush}"
          BorderBrush="{DynamicResource ThemeBorderLowBrush}"
          BorderThickness="1"
          Padding="10">
    <Grid RowDefinitions="Auto,*"
          RowSpacing="8">
      <StackPanel Orientation="Horizontal"
                  Spacing="8">
        <TextBlock Text="Dimension Styles"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <TextBox Width="160"
                 Watermark="Search..."
                 Text="{CompiledBinding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        <Button Content="Clear"
                Command="{CompiledBinding ClearSearchCommand}" />
        <TextBox Width="160"
                 Watermark="Filter..."
                 Text="{CompiledBinding FilterText, UpdateSourceTrigger=PropertyChanged}" />
        <Button Content="Clear"
                Command="{CompiledBinding ClearFilterCommand}" />
      </StackPanel>
      <DataGrid Grid.Row="1"
                ItemsSource="{CompiledBinding StylesView}"
                ColumnDefinitionsSource="{CompiledBinding ColumnDefinitions}"
                SortingModel="{CompiledBinding SortingModel}"
                FilteringModel="{CompiledBinding FilteringModel}"
                SearchModel="{CompiledBinding SearchModel}"
                SelectedItem="{CompiledBinding SelectedStyle}"
                RowHeight="56"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                CanUserReorderColumns="True"
                CanUserResizeColumns="True"
                GridLinesVisibility="All"
                IsReadOnly="True" />
    </Grid>
  </Border>
</UserControl>
