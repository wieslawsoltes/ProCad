<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ACadInspector.ViewModels"
             mc:Ignorable="d"
             x:Class="ACadInspector.Views.CadDxfSemanticsView"
             x:DataType="vm:CadDxfSemanticsViewModel">
  <Grid RowDefinitions="Auto,Auto,Auto,*"
        Margin="12">
    <TextBlock Text="{CompiledBinding SelectedTitle}"
               FontWeight="SemiBold" />
    <TextBlock Grid.Row="1"
               Text="DXF Property Mapping"
               Margin="0,8,0,4"
               FontWeight="SemiBold" />
    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                Spacing="8"
                Margin="0,0,0,4">
      <TextBlock Text="Search"
                 VerticalAlignment="Center" />
      <TextBox Width="200"
               Watermark="Search..."
               Text="{CompiledBinding SearchText, UpdateSourceTrigger=PropertyChanged}" />
      <Button Content="Clear"
              Command="{CompiledBinding ClearSearchCommand}" />
      <TextBlock Text="Filter"
                 Margin="12,0,0,0"
                 VerticalAlignment="Center" />
      <TextBox Width="200"
               Watermark="Filter..."
               Text="{CompiledBinding FilterText, UpdateSourceTrigger=PropertyChanged}" />
      <Button Content="Clear"
              Command="{CompiledBinding ClearFilterCommand}" />
    </StackPanel>
    <DataGrid Grid.Row="3"
              ItemsSource="{CompiledBinding PropertyRowsView}"
              ColumnDefinitionsSource="{CompiledBinding PropertyColumnDefinitions}"
              SortingModel="{CompiledBinding SortingModel}"
              FilteringModel="{CompiledBinding FilteringModel}"
              SearchModel="{CompiledBinding SearchModel}"
              AutoGenerateColumns="False"
              CanUserSortColumns="True"
              CanUserReorderColumns="True"
              CanUserResizeColumns="True"
              GridLinesVisibility="All"
              IsReadOnly="True" />
  </Grid>
</UserControl>
