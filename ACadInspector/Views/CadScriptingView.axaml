<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ACadInspector.ViewModels"
             xmlns:edit="using:AvaloniaEdit"
             xmlns:i="using:Avalonia.Xaml.Interactivity"
             xmlns:behaviors="using:ACadInspector.Behaviors"
             mc:Ignorable="d"
             x:Class="ACadInspector.Views.CadScriptingView"
             x:DataType="vm:CadScriptingViewModel">
  <TabControl Margin="12">
    <TabItem Header="C# Script">
      <Grid RowDefinitions="Auto,*"
            RowSpacing="8">
        <StackPanel Orientation="Horizontal"
                    Spacing="8">
          <Button Content="Run"
                  Command="{CompiledBinding RunCommand}" />
          <Button Content="Cancel"
                  Command="{CompiledBinding CancelCommand}" />
          <Button Content="Clear Output"
                  Command="{CompiledBinding ClearOutputCommand}" />
          <Button Content="Reset Template"
                  Command="{CompiledBinding ResetTemplateCommand}" />
          <TextBlock Text="{CompiledBinding StatusMessage}"
                     VerticalAlignment="Center"
                     Margin="12,0,0,0" />
        </StackPanel>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto,*"
              ColumnSpacing="8">
          <Border BorderThickness="1"
                  CornerRadius="6"
                  BorderBrush="{DynamicResource ThemeBorderLowBrush}">
            <edit:TextEditor Document="{CompiledBinding ScriptDocument}"
                             ShowLineNumbers="True"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto">
              <i:Interaction.Behaviors>
                <behaviors:TextMateBehavior GrammarExtension=".cs" Theme="Dark" />
              </i:Interaction.Behaviors>
            </edit:TextEditor>
          </Border>

          <GridSplitter Grid.Column="1"
                        Width="6"
                        Background="{DynamicResource ThemeBorderLowBrush}" />

          <Border Grid.Column="2"
                  BorderThickness="1"
                  CornerRadius="6"
                  BorderBrush="{DynamicResource ThemeBorderLowBrush}">
            <edit:TextEditor Document="{CompiledBinding OutputDocument}"
                             IsReadOnly="True"
                             ShowLineNumbers="False"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
          </Border>
        </Grid>
      </Grid>
    </TabItem>

    <TabItem Header="Command Script">
      <Grid RowDefinitions="Auto,Auto,Auto,*"
            RowSpacing="8">
        <StackPanel Orientation="Horizontal"
                    Spacing="8">
          <Button Content="Run"
                  Command="{CompiledBinding RunCommandScriptCommand}" />
          <Button Content="Cancel"
                  Command="{CompiledBinding CancelCommandScriptCommand}" />
          <Button Content="Clear Output"
                  Command="{CompiledBinding ClearCommandOutputCommand}" />
          <Button Content="Reset Template"
                  Command="{CompiledBinding ResetCommandTemplateCommand}" />
          <CheckBox Content="Continue On Error"
                    IsChecked="{CompiledBinding ContinueOnCommandError, Mode=TwoWay}"
                    VerticalAlignment="Center" />
          <TextBlock Text="{CompiledBinding CommandStatusMessage}"
                     VerticalAlignment="Center"
                     Margin="12,0,0,0" />
        </StackPanel>

        <Border Grid.Row="1"
                CornerRadius="8"
                BorderThickness="1"
                Padding="8"
                BorderBrush="{DynamicResource ThemeBorderLowBrush}">
          <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,*,Auto"
                ColumnSpacing="8">
            <Button Content="Record"
                    Command="{CompiledBinding StartRecordingCommand}" />
            <Button Grid.Column="1"
                    Content="Pause"
                    Command="{CompiledBinding PauseRecordingCommand}" />
            <Button Grid.Column="2"
                    Content="Resume"
                    Command="{CompiledBinding ResumeRecordingCommand}" />
            <Button Grid.Column="3"
                    Content="Stop"
                    Command="{CompiledBinding StopRecordingCommand}" />
            <Button Grid.Column="4"
                    Content="Clear"
                    Command="{CompiledBinding ClearRecordingCommand}" />
            <Button Grid.Column="5"
                    Content="Load Recording"
                    Command="{CompiledBinding LoadRecordingCommand}" />
            <Button Grid.Column="6"
                    Content="Save Recording"
                    Command="{CompiledBinding SaveRecordingCommand}" />
            <TextBox Grid.Column="7"
                     Text="{CompiledBinding RecordingSavePath, Mode=TwoWay}"
                     Watermark="Recording path (.scr)" />
            <TextBlock Grid.Column="8"
                       VerticalAlignment="Center"
                       Text="{CompiledBinding RecordingStatusMessage}" />
          </Grid>
        </Border>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    Spacing="12">
          <CheckBox Content="Include Failed Commands"
                    IsChecked="{CompiledBinding IncludeFailedRecordedCommands, Mode=TwoWay}" />
          <CheckBox Content="Include Metadata Comments"
                    IsChecked="{CompiledBinding IncludeRecordingMetadataComments, Mode=TwoWay}" />
          <TextBlock Text="{CompiledBinding RecordedCommandCount, StringFormat='Recorded: {0}'}"
                     VerticalAlignment="Center" />
        </StackPanel>

        <Grid Grid.Row="3"
              ColumnDefinitions="*,Auto,*"
              ColumnSpacing="8">
          <Border BorderThickness="1"
                  CornerRadius="6"
                  BorderBrush="{DynamicResource ThemeBorderLowBrush}">
            <edit:TextEditor Document="{CompiledBinding CommandScriptDocument}"
                             ShowLineNumbers="True"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
          </Border>

          <GridSplitter Grid.Column="1"
                        Width="6"
                        Background="{DynamicResource ThemeBorderLowBrush}" />

          <Border Grid.Column="2"
                  BorderThickness="1"
                  CornerRadius="6"
                  BorderBrush="{DynamicResource ThemeBorderLowBrush}">
            <edit:TextEditor Document="{CompiledBinding CommandOutputDocument}"
                             IsReadOnly="True"
                             ShowLineNumbers="False"
                             HorizontalScrollBarVisibility="Auto"
                             VerticalScrollBarVisibility="Auto" />
          </Border>
        </Grid>
      </Grid>
    </TabItem>
  </TabControl>
</UserControl>
