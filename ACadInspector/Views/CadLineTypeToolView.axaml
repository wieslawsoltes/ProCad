<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:ACadInspector.ViewModels"
             mc:Ignorable="d"
             x:Class="ACadInspector.Views.CadLineTypeToolView"
             x:DataType="vm:CadLineTypeToolViewModel">
  <Border Background="{DynamicResource ThemeControlLowBrush}"
          BorderBrush="{DynamicResource ThemeBorderLowBrush}"
          BorderThickness="1"
          Padding="10">
    <Grid RowDefinitions="Auto,Auto,*"
          RowSpacing="8">
      <StackPanel Orientation="Horizontal"
                  Spacing="8">
        <TextBlock Text="Line Types"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center" />
        <TextBox Width="140"
                 Watermark="Search..."
                 Text="{CompiledBinding SearchText, UpdateSourceTrigger=PropertyChanged}" />
        <Button Classes="fluent-icon" Tag="{StaticResource ClearIconPath}" Content="Clear"
                Command="{CompiledBinding ClearSearchCommand}" />
        <TextBox Width="140"
                 Watermark="Filter..."
                 Text="{CompiledBinding FilterText, UpdateSourceTrigger=PropertyChanged}" />
        <Button Classes="fluent-icon" Tag="{StaticResource ClearIconPath}" Content="Clear"
                Command="{CompiledBinding ClearFilterCommand}" />
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Orientation="Horizontal"
                  Spacing="8">
        <Button Classes="fluent-icon" Tag="{StaticResource NewDocumentIconPath}" Content="New"
                Command="{CompiledBinding NewLineTypeCommand}" />
        <Button Classes="fluent-icon" Tag="{StaticResource CopyIconPath}" Content="Duplicate"
                Command="{CompiledBinding DuplicateLineTypeCommand}" />
        <Button Classes="fluent-icon" Tag="{StaticResource DeleteIconPath}" Content="Delete"
                Command="{CompiledBinding DeleteLineTypeCommand}" />
        <Button Classes="fluent-icon" Tag="{StaticResource CheckmarkIconPath}" Content="Set Current"
                Command="{CompiledBinding SetCurrentLineTypeCommand}" />
        <Button Classes="fluent-icon" Tag="{StaticResource CheckmarkIconPath}" Content="Apply"
                Command="{CompiledBinding ApplyLineTypeCommand}" />
        <Button Classes="fluent-icon" Tag="{StaticResource UndoIconPath}" Content="Revert"
                Command="{CompiledBinding RevertLineTypeCommand}" />
      </StackPanel>

      <DataGrid Grid.Row="2"
                ItemsSource="{CompiledBinding LineTypesView}"
                ColumnDefinitionsSource="{CompiledBinding ColumnDefinitions}"
                SortingModel="{CompiledBinding SortingModel}"
                FilteringModel="{CompiledBinding FilteringModel}"
                SearchModel="{CompiledBinding SearchModel}"
                SelectedItem="{CompiledBinding SelectedLineType}"
                RowHeight="56"
                AutoGenerateColumns="False"
                CanUserSortColumns="True"
                CanUserReorderColumns="False"
                CanUserResizeColumns="True"
                GridLinesVisibility="All"
                IsReadOnly="True" />
    </Grid>
  </Border>
</UserControl>
